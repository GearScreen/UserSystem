datasource db {
  provider = "mysql"
  relationMode = "prisma"
}

generator client {
  provider = "prisma-client-js"
  // output   = "../app/generated/prisma"
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum Status {
  ACTIVE
  INACTIVE
  SUSPENDED
  LOCKED
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  username        String?   @unique @db.VarChar(100)
  role            Role      @default(USER)
  status          Status    @default(ACTIVE)

  // Password
  passwordHash    String    @db.VarChar(255) @map("password_hash")
  resetToken      String?   @unique @map("password_reset_token")
  resetExpires    DateTime? @map("password_reset_expires_at")

  // Security fields
  // loginAttempts   Int       @default(0) @map("login_attempts")
  // lockedUntil     DateTime? @map("locked_until")

  // Account Verification
  emailVerified  Boolean @default(false) @map("email_verified")
  verificationToken     String?   @unique @map("verification_token")
  verificationExpiresAt DateTime? @map("verification_expires_at")

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  lastLogin       DateTime? @map("last_login")

  @@map("users")
  @@index([email])
  @@index([role])
}

model LoginAttempt {
  id              Int       @id @default(autoincrement())
  ipAddress       String    @map("ip_address") @db.VarChar(45)
  attemptCount    Int       @default(1) @map("attempt_count")
  firstAttemptAt  DateTime  @map("first_attempt_at")
  lastAttemptAt   DateTime  @map("last_attempt_at")
  lockedUntil     DateTime? @map("locked_until")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([ipAddress])
  @@index([lockedUntil])
  @@index([lastAttemptAt])
  @@map("login_attempts")
}
